{
  "hosting": {
    "site": "pragmalogixai-app",
    "public": ".firebase-public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "pragmalogixai-frontend",
          "region": "us-central1"
        }
      }
    ]
  }
}
