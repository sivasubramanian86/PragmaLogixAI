# Local environment variables for PragmaLogixAI frontend
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.

# Base URL for the PragmaLogixAI backend API.
# In development: point to your locally running FastAPI server.
# In production: set to your Cloud Run service URL (e.g. https://pragmalogixai-backend-xxx-uc.a.run.app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
